# Copy to .env.local and fill in with the values `supabase start` prints
# (API URL, anon key). Never commit .env.local -- it's gitignored.
#
# The service role key is intentionally NOT listed here: this app's
# Next.js code never uses it. It only ever appears as an environment
# variable read directly by test/rls.integration.test.ts and the CI
# workflow, both of which read it from the process environment, never from
# a file that could accidentally get committed.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
